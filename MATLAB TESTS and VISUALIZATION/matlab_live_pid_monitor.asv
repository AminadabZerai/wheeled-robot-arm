clear; clc; close all;

%% Connection
port   = "COM3";
baud   = 115200;
device = serialport(port, baud);
configureTerminator(device, "LF");
flush(device);
pause(2);
disp("Connected to Arduino.");

%% Wait for READY
disp("Waiting for READY...");
device.Timeout = 30;
while true
    try
        line = strtrim(string(readline(device)));
        disp("RX: " + line);
        if contains(line, "READY")
            disp("Arduino READY"); break;
        end
    catch; continue;
    end
end
device.Timeout = 2;

%% ================================================================
%% FIGURE — Dark mode palette
%% ================================================================
bg      = [0.12 0.12 0.12];
ax_bg   = [0.18 0.18 0.18];
txt_col = [0.92 0.92 0.92];
vel_col = [0.25 0.60 1.00];   % bright blue
sp_col  = [1.00 0.75 0.10];   % amber
pow_col = [0.20 0.85 0.50];   % green
grid_col= [0.30 0.30 0.30];

fig = figure('Name','Live PID Monitor','Color',bg,'Position',[80 80 1000 650]);

%% UI Controls
uicontrol('Style','text','Units','normalized','BackgroundColor',bg,...
    'ForegroundColor',txt_col,...
    'Position',[0.01 0.94 0.13 0.04],'String','Setpoint (rad/s):');
sp_box = uicontrol('Style','edit','Units','normalized',...
    'BackgroundColor',ax_bg,'ForegroundColor',txt_col,...
    'Position',[0.15 0.94 0.09 0.04],'String','0');
uicontrol('Style','pushbutton','Units','normalized',...
    'BackgroundColor',[0.20 0.45 0.80],'ForegroundColor',txt_col,...
    'Position',[0.25 0.94 0.07 0.04],'String','Send',...
    'Callback', @(~,~) send_setpoint(device, sp_box));
uicontrol('Style','pushbutton','Units','normalized',...
    'BackgroundColor',[0.70 0.20 0.20],'ForegroundColor',txt_col,...
    'Position',[0.33 0.94 0.07 0.04],'String','Stop',...
    'Callback', @(~,~) stop_motor(device));

% Multi-setpoint sequence controls
uicontrol('Style','text','Units','normalized','BackgroundColor',bg,...
    'ForegroundColor',txt_col,...
    'Position',[0.43 0.94 0.18 0.04],...
    'String','Sequence (e.g. 7,10,13,15):');
seq_box = uicontrol('Style','edit','Units','normalized',...
    'BackgroundColor',ax_bg,'ForegroundColor',txt_col,...
    'Position',[0.62 0.94 0.15 0.04],'String','7,10,13,15');
uicontrol('Style','text','Units','normalized','BackgroundColor',bg,...
    'ForegroundColor',txt_col,...
    'Position',[0.78 0.94 0.08 0.04],'String','Hold (s):');
hold_box = uicontrol('Style','edit','Units','normalized',...
    'BackgroundColor',ax_bg,'ForegroundColor',txt_col,...
    'Position',[0.87 0.94 0.05 0.04],'String','8');
uicontrol('Style','pushbutton','Units','normalized',...
    'BackgroundColor',[0.20 0.60 0.30],'ForegroundColor',txt_col,...
    'Position',[0.93 0.94 0.06 0.04],'String','Run Seq',...
    'Callback', @(~,~) run_sequence(device, seq_box, hold_box));

% Status label
status_lbl = uicontrol('Style','text','Units','normalized',...
    'BackgroundColor',bg,'ForegroundColor',[0.60 0.90 0.60],...
    'Position',[0.01 0.90 0.98 0.03],...
    'String','Waiting for data...','HorizontalAlignment','left',...
    'FontSize',10);

%% Velocity subplot
ax1 = subplot(2,1,1);
set(ax1,'Color',ax_bg,'XColor',txt_col,'YColor',txt_col,...
    'GridColor',grid_col,'GridAlpha',0.5);
h_vel = animatedline(ax1,'Color',vel_col,'LineWidth',1.5,'DisplayName','Velocity');
h_sp  = animatedline(ax1,'Color',sp_col,'LineStyle','--','LineWidth',1.2,'DisplayName','Setpoint');
ylabel(ax1,'Velocity (rad/s)','Color',txt_col);
legend(ax1,'show','TextColor',txt_col,'Color',ax_bg);
grid(ax1,'on'); box(ax1,'on');
title(ax1,'Velocity Tracking','Color',txt_col);

%% Power subplot
ax2 = subplot(2,1,2);
set(ax2,'Color',ax_bg,'XColor',txt_col,'YColor',txt_col,...
    'GridColor',grid_col,'GridAlpha',0.5);
h_pow = animatedline(ax2,'Color',pow_col,'LineWidth',1.2);
ylabel(ax2,'Motor Power (%)','Color',txt_col);
xlabel(ax2,'Time (s)','Color',txt_col);
grid(ax2,'on'); box(ax2,'on');
title(ax2,'Motor Power Output','Color',txt_col);

%% ================================================================
%% CALLBACKS
%% ================================================================
function send_setpoint(device, sp_box)
    val = str2double(get(sp_box, 'String'));
    if ~isnan(val)
        writeline(device, sprintf('S:%.2f', val));
        fprintf('Setpoint sent: %.2f rad/s\n', val);
    end
end

function stop_motor(device)
    writeline(device, 'R:');
    writeline(device, 'S:0.00');
    fprintf('Motor stopped.\n');
end

function run_sequence(device, seq_box, hold_box)
    seq_str  = get(seq_box,  'String');
    hold_s   = str2double(get(hold_box, 'String'));
    if isnan(hold_s) || hold_s <= 0; hold_s = 8; end

    parts    = strsplit(strtrim(seq_str), ',');
    setpoints = str2double(parts);
    setpoints = setpoints(~isnan(setpoints));

    if isempty(setpoints)
        fprintf('No valid setpoints in sequence.\n');
        return;
    end

    fprintf('Running sequence: [%s] for %.1fs each\n', ...
        strjoin(arrayfun(@(x) sprintf('%.1f',x), setpoints,...
        'UniformOutput',false), ', '), hold_s);

    for k = 1:length(setpoints)
        sp = setpoints(k);
        writeline(device, sprintf('S:%.2f', sp));
        fprintf('  -> Setpoint: %.2f rad/s\n', sp);
        pause(hold_s);
    end

    % Stop after sequence
    writeline(device, 'R:');
    writeline(device, 'S:0.00');
    fprintf('Sequence complete. Motor stopped.\n');
end

%% ================================================================
%% STORAGE
%% ================================================================
all_data    = zeros(10000, 7); % [Time_ms, Setpoint, Vel, Power, Kp, Ki, Kd]
n           = 0;
time_window = 15;
start_time  = [];

%% ================================================================
%% MAIN STREAMING LOOP
%% ================================================================
try
    while isvalid(fig)
        try
            line = readline(device);
        catch
            drawnow; continue;
        end

        if ~(isstring(line) || ischar(line)); continue; end
        line = strtrim(string(line));
        if strlength(line) == 0; continue; end

        data = str2double(split(line, ','));
        if length(data) ~= 7 || any(isnan(data)); continue; end

        t_ms  = data(1);
        sp_rx = data(2);
        vel   = data(3);
        power = data(4);
        kp    = data(5);
        ki    = data(6);
        kd    = data(7);

        if isempty(start_time); start_time = t_ms; end
        t = (t_ms - start_time) / 1000;

        % Store
        n = n + 1;
        if n > size(all_data, 1)
            all_data = [all_data; zeros(10000, 7)];
        end
        all_data(n, :) = [t_ms, sp_rx, vel, power, kp, ki, kd];

        % Plot
        addpoints(h_vel, t, vel);
        addpoints(h_sp,  t, sp_rx);
        addpoints(h_pow, t, power);

        t_lo = max(0, t - time_window);
        t_hi = max(t, t_lo + 0.001);
        xlim(ax1, [t_lo t_hi]);
        xlim(ax2, [t_lo t_hi]);

        set(status_lbl, 'String', sprintf(...
            't=%.1fs  sp=%.2f rad/s  vel=%.3f rad/s  pwr=%.1f%%  Kp=%.1f  Ki=%.1f  Kd=%.1f', ...
            t, sp_rx, vel, power, kp, ki, kd));

        drawnow limitrate;
    end

catch ME
    fprintf('Loop stopped: %s\n', ME.message);
end

%% ================================================================
%% SAVE
%% ================================================================
try; clear device; catch; end

save_dir = 'C:/Users/Amine/Desktop/Project_Make_it_Or_Break_It/wheeled-robot-arm/MATLAB TESTS and VISUALIZATION/CSVs/';
if ~exist(save_dir, 'dir'); mkdir(save_dir); end

if n > 0
    all_data = all_data(1:n, :);
    filename = fullfile(save_dir, sprintf('pid_response_%s.csv', ...
               datestr(now, 'yyyy-mm-dd_HH-MM-SS')));
    T = array2table(all_data, 'VariableNames', ...
        {'Time_ms','Setpoint_rads','Velocity_rads','Power_pct',...
         'Kp','Ki','Kd'});
    writetable(T, filename);
    fprintf('Saved %d samples to %s\n', n, filename);
else
    fprintf('No data collected — nothing saved.\n');
end

fprintf('Session ended.\n');